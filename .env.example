# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# Redis (Upstash) — optional, degrades gracefully
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# CORS
CORS_ORIGINS=["chrome-extension://your-extension-id","http://localhost:3000"]

# Rate limits
RATE_LIMIT_FREE=10/day
RATE_LIMIT_PRO=200/day

# Dev mode — set a static API key for local testing without Supabase Auth
DEV_API_KEY=ghostproof-dev-key-change-me
